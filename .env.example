# Variáveis de ambiente do Alquimia Verbal
# Copie este arquivo para .env e preencha com seus valores reais.

# ── Supabase (obrigatório) ──────────────────────────────────────────────────
# Encontre em: Supabase Dashboard > Project Settings > API

VITE_SUPABASE_URL=https://SEU_PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=SUA_ANON_KEY

# ── Créditos do jogo (opcional) ─────────────────────────────────────────────
# Exibidos na tela de créditos do menu.

VITE_GAME_CREATOR=Nicolas Oliveira
VITE_GAME_MENTOR=Sergio Claudino

# ── NOTA IMPORTANTE: Autenticação do Professor ─────────────────────────────
# A senha do professor NÃO é definida via .env!
# Ela é armazenada com hash bcrypt no banco de dados Supabase.
#
# Para configurar/alterar a senha do professor:
#   1. Acesse Supabase Dashboard > SQL Editor
#   2. Execute: SELECT set_professor_password('nova_senha_aqui');
#   3. A senha padrão inicial (definida em 002_professor_auth.sql) é: prof2026
# ───────────────────────────────────────────────────────────────────────────
